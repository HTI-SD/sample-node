<%- include('partials/header', { title: 'Weather Advisory – FarmSeva', activePage: 'weather' }) %>

<div class="bg-gradient-to-r from-sky-800 to-sky-600 py-12 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-center space-x-2 text-sky-300 text-sm mb-3">
      <a href="/" class="hover:text-white">Home</a><span>/</span>
      <span class="text-white">Weather Advisory</span>
    </div>
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">🌤 Weather & Crop Advisory</h1>
    <p class="text-sky-200">Real-time weather + AI-powered crop recommendations for your farm location.</p>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <!-- Location selector -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 mb-7 flex flex-wrap gap-3 items-center" data-aos="fade-up">
    <span class="text-gray-700 font-semibold">📍 Your Location:</span>
    <div class="flex-1 flex items-center space-x-3">
      <input type="text" id="location-input" value="Anand, Gujarat" placeholder="Enter village, city, or PIN code"
        class="flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:border-sky-400 focus:ring-2 focus:ring-sky-100 outline-none transition-all">
      <button onclick="updateLocation()" class="bg-sky-600 hover:bg-sky-700 text-white px-5 py-2.5 rounded-xl font-semibold text-sm transition-colors">Update</button>
    </div>
    <div class="flex flex-wrap gap-2">
      <button onclick="setLocation('Anand, Gujarat')" class="location-chip">Anand</button>
      <button onclick="setLocation('Vadodara, Gujarat')" class="location-chip">Vadodara</button>
      <button onclick="setLocation('Rajkot, Gujarat')" class="location-chip">Rajkot</button>
      <button onclick="setLocation('Ahmedabad, Gujarat')" class="location-chip">Ahmedabad</button>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-7">

    <!-- Current Weather Card -->
    <div class="lg:col-span-1" data-aos="fade-up">
      <div class="bg-gradient-to-br from-sky-500 to-sky-700 rounded-3xl p-6 text-white shadow-lg relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -translate-y-8 translate-x-8"></div>
        <div class="absolute bottom-0 left-0 w-24 h-24 bg-white/10 rounded-full translate-y-6 -translate-x-6"></div>

        <div class="relative">
          <div class="flex items-start justify-between mb-4">
            <div>
              <p class="text-sky-200 text-sm font-medium" id="current-location-label">Anand, Gujarat</p>
              <p class="text-sky-100 text-xs" id="current-date-label">Saturday, April 4</p>
            </div>
            <div class="text-5xl" id="current-weather-icon">⛅</div>
          </div>
          <div class="text-7xl font-bold mb-1" id="current-temp">28°</div>
          <div class="text-sky-200 font-medium mb-5" id="current-desc">Partly Cloudy</div>
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-white/10 rounded-xl p-3">
              <div class="text-xs text-sky-200">💧 Humidity</div>
              <div class="font-bold text-lg" id="current-humidity">62%</div>
            </div>
            <div class="bg-white/10 rounded-xl p-3">
              <div class="text-xs text-sky-200">💨 Wind</div>
              <div class="font-bold text-lg" id="current-wind">12 km/h</div>
            </div>
            <div class="bg-white/10 rounded-xl p-3">
              <div class="text-xs text-sky-200">🌡 Feels Like</div>
              <div class="font-bold text-lg">31°C</div>
            </div>
            <div class="bg-white/10 rounded-xl p-3">
              <div class="text-xs text-sky-200">🌧 Rain Chance</div>
              <div class="font-bold text-lg" id="current-rain">20%</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Farming Alert -->
      <div class="bg-soil-50 border border-soil-200 rounded-2xl p-4 mt-4">
        <p class="font-bold text-soil-800 text-sm mb-2">🌾 Today's Farming Advisory</p>
        <p class="text-soil-700 text-xs leading-relaxed" id="farm-advisory">Good day for field operations. Avoid pesticide spray — wind speed moderate. Ideal for irrigation work in morning hours.</p>
      </div>
    </div>

    <!-- 7-Day Forecast -->
    <div class="lg:col-span-2" data-aos="fade-up" data-aos-delay="100">
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6">
        <h3 class="font-bold text-gray-900 text-lg mb-5">📅 7-Day Forecast</h3>
        <div class="space-y-3" id="forecast-list">
          <!-- Generated by JS -->
        </div>
      </div>

      <!-- Crop Calendar -->
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 mt-5">
        <h3 class="font-bold text-gray-900 text-lg mb-4">🗓 Crop Activity Calendar</h3>
        <div class="space-y-3">
          <div class="crop-cal-item bg-green-50 border-l-4 border-green-500">
            <span class="text-sm font-semibold text-green-800">🌱 Optimal Sowing Window</span>
            <span class="text-xs text-green-600 ml-2">April 5 – 15</span>
            <p class="text-xs text-green-600 mt-0.5">Ideal for Summer Vegetables (Okra, Bottle Gourd, Cucumber)</p>
          </div>
          <div class="crop-cal-item bg-blue-50 border-l-4 border-blue-500">
            <span class="text-sm font-semibold text-blue-800">💧 Irrigation Recommended</span>
            <span class="text-xs text-blue-600 ml-2">Today & Tomorrow</span>
            <p class="text-xs text-blue-600 mt-0.5">Low rain probability. Standing crops may need supplemental irrigation.</p>
          </div>
          <div class="crop-cal-item bg-amber-50 border-l-4 border-amber-500">
            <span class="text-sm font-semibold text-amber-800">🌾 Wheat Harvest Window</span>
            <span class="text-xs text-amber-600 ml-2">April 10 – 20</span>
            <p class="text-xs text-amber-600 mt-0.5">Dry weather expected. Good conditions for combine harvester operation.</p>
          </div>
          <div class="crop-cal-item bg-red-50 border-l-4 border-red-500">
            <span class="text-sm font-semibold text-red-800">⚠️ Pest Alert</span>
            <span class="text-xs text-red-600 ml-2">Next 5 Days</span>
            <p class="text-xs text-red-600 mt-0.5">High aphid risk for cotton crops. Monitor closely. Apply neem oil spray preventively.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Crop-specific weather -->
  <div class="mt-7 bg-white rounded-3xl shadow-sm border border-gray-100 p-6" data-aos="fade-up">
    <h3 class="font-bold text-gray-900 text-lg mb-5">🌾 Weather Impact on Your Crops</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="crop-weather-card bg-farm-50">
        <div class="text-4xl mb-2">🌾</div>
        <h4 class="font-semibold text-gray-800 text-sm">Wheat</h4>
        <div class="flex items-center space-x-1 mt-1"><span class="w-2 h-2 bg-green-500 rounded-full"></span><span class="text-xs text-green-600 font-medium">Good Conditions</span></div>
        <p class="text-xs text-gray-500 mt-2">Temperature and humidity ideal for maturity. Prepare for harvest in 6–8 days.</p>
      </div>
      <div class="crop-weather-card bg-amber-50">
        <div class="text-4xl mb-2">🍅</div>
        <h4 class="font-semibold text-gray-800 text-sm">Tomato</h4>
        <div class="flex items-center space-x-1 mt-1"><span class="w-2 h-2 bg-yellow-500 rounded-full"></span><span class="text-xs text-yellow-600 font-medium">Monitor Closely</span></div>
        <p class="text-xs text-gray-500 mt-2">High humidity increases late blight risk. Apply preventive fungicide spray today.</p>
      </div>
      <div class="crop-weather-card bg-blue-50">
        <div class="text-4xl mb-2">🍚</div>
        <h4 class="font-semibold text-gray-800 text-sm">Rice (Paddy)</h4>
        <div class="flex items-center space-x-1 mt-1"><span class="w-2 h-2 bg-green-500 rounded-full"></span><span class="text-xs text-green-600 font-medium">Good Conditions</span></div>
        <p class="text-xs text-gray-500 mt-2">Water levels optimal. No flood risk in next 7 days. Good for transplanting.</p>
      </div>
      <div class="crop-weather-card bg-purple-50">
        <div class="text-4xl mb-2">🌿</div>
        <h4 class="font-semibold text-gray-800 text-sm">Cotton</h4>
        <div class="flex items-center space-x-1 mt-1"><span class="w-2 h-2 bg-red-500 rounded-full"></span><span class="text-xs text-red-600 font-medium">Alert</span></div>
        <p class="text-xs text-gray-500 mt-2">Wind speeds may damage bolls. Stake plants and monitor for aphid infestation.</p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  const weatherData = {
    'Anand, Gujarat': { temp: '28°', desc: 'Partly Cloudy', icon: '⛅', humidity: '62%', wind: '12 km/h', rain: '20%', advisory: 'Good day for field operations. Avoid pesticide spray — wind speed moderate. Ideal for irrigation work in morning hours.' },
    'Vadodara, Gujarat': { temp: '31°', desc: 'Sunny', icon: '☀️', humidity: '55%', wind: '8 km/h', rain: '5%', advisory: 'Clear sky, excellent for drone spraying. High temperature — irrigate evening hours for best results.' },
    'Rajkot, Gujarat': { temp: '33°', desc: 'Hot & Dry', icon: '🌤', humidity: '42%', wind: '15 km/h', rain: '2%', advisory: 'Very dry conditions. Increase irrigation frequency. Postpone chemical spraying due to strong wind.' },
    'Ahmedabad, Gujarat': { temp: '34°', desc: 'Sunny & Hot', icon: '☀️', humidity: '48%', wind: '10 km/h', rain: '8%', advisory: 'Heat wave conditions. Water crops early morning or late evening. Mulching recommended to retain moisture.' },
  };

  const forecastDays = [
    { day: 'Today', icon: '⛅', high: '31°', low: '22°', rain: '20%', desc: 'Partly Cloudy' },
    { day: 'Tomorrow', icon: '🌤', high: '33°', low: '23°', rain: '10%', desc: 'Mostly Sunny' },
    { day: 'Sunday', icon: '☀️', high: '35°', low: '24°', rain: '5%', desc: 'Clear & Hot' },
    { day: 'Monday', icon: '🌦', high: '29°', low: '21°', rain: '60%', desc: 'Chance of Rain' },
    { day: 'Tuesday', icon: '🌧', high: '27°', low: '20°', rain: '80%', desc: 'Rainy' },
    { day: 'Wednesday', icon: '⛈', high: '26°', low: '19°', rain: '70%', desc: 'Thunderstorm' },
    { day: 'Thursday', icon: '🌤', high: '30°', low: '21°', rain: '25%', desc: 'Clearing Up' },
  ];

  function renderForecast() {
    const list = document.getElementById('forecast-list');
    list.innerHTML = forecastDays.map(d => `
      <div class="flex items-center justify-between py-2.5 border-b border-gray-50 last:border-0">
        <div class="w-24 text-sm font-semibold text-gray-700">${d.day}</div>
        <div class="text-2xl">${d.icon}</div>
        <div class="flex-1 mx-3 text-sm text-gray-500">${d.desc}</div>
        <div class="text-xs text-blue-500 w-10 text-center">💧${d.rain}</div>
        <div class="text-sm font-bold text-gray-800 w-16 text-right">${d.high} / <span class="text-gray-400 font-normal">${d.low}</span></div>
      </div>
    `).join('');
  }

  function setLocation(loc) {
    document.getElementById('location-input').value = loc;
    updateLocation();
  }

  function updateLocation() {
    const loc = document.getElementById('location-input').value.trim();
    const data = weatherData[loc] || weatherData['Anand, Gujarat'];
    document.getElementById('current-location-label').textContent = loc;
    document.getElementById('current-weather-icon').textContent = data.icon;
    document.getElementById('current-temp').textContent = data.temp;
    document.getElementById('current-desc').textContent = data.desc;
    document.getElementById('current-humidity').textContent = data.humidity;
    document.getElementById('current-wind').textContent = data.wind;
    document.getElementById('current-rain').textContent = data.rain;
    document.getElementById('farm-advisory').textContent = data.advisory;
    showToast('Location Updated', `Weather data for ${loc} loaded.`, '📍');
  }

  // Set today's date
  document.getElementById('current-date-label').textContent = new Date().toLocaleDateString('en-IN', { weekday: 'long', month: 'long', day: 'numeric' });

  renderForecast();
</script>
