      <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded-full font-bold">2</span>
    </h2>

    <!-- Booking 1 — On the Way (TRACTOR) -->
    <div class="booking-track-card mb-5" data-aos="fade-up">
      <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
        <div class="flex items-center space-x-3">
          <div class="w-14 h-14 bg-amber-50 rounded-2xl flex items-center justify-center text-3xl">🚜</div>
          <div>
            <h4 class="font-bold text-gray-900">Mahindra Tractor 45HP</h4>
            <p class="text-gray-500 text-xs">April 8–9, 2025 • 2 days • Anand, Gujarat</p>
            <p class="text-farm-700 font-semibold text-sm">₹1,600 <span class="text-gray-400 font-normal text-xs">(Cash on arrival)</span></p>
