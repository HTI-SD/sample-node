        </div>
        <div class="flex items-center space-x-2">
          <div class="status-badge status-onway" data-translate="status-on-way">🚗 On the Way</div>
          <div class="text-xs text-gray-400">#FS-2025-0412</div>
        </div>
      </div>

      <!-- Progress Stepper -->
      <div class="tracking-stepper mb-5">
        <div class="track-step done-step">
          <div class="track-dot done-dot">✓</div>
          <div class="track-label" data-translate="track-booked">Booked</div>
          <div class="track-time text-xs text-gray-400">Apr 6, 2PM</div>
        </div>
        <div class="track-line done-line"></div>
        <div class="track-step done-step">
          <div class="track-dot done-dot">✓</div>
          <div class="track-label" data-translate="track-confirmed">Confirmed</div>
          <div class="track-time text-xs text-gray-400">Apr 6, 4PM</div>
        </div>
        <div class="track-line active-line"></div>
        <div class="track-step active-step">
          <div class="track-dot active-dot">
            <div class="w-2 h-2 bg-white rounded-full animate-pulse"></div>
          </div>
          <div class="track-label text-farm-600 font-bold" data-translate="track-on-way">On the Way</div>
          <div class="track-time text-xs text-farm-500 font-medium">Now</div>
        </div>
        <div class="track-line pending-line"></div>
        <div class="track-step pending-step">
          <div class="track-dot pending-dot">4</div>
          <div class="track-label text-gray-400" data-translate="track-arrived">Arrived</div>
          <div class="track-time text-xs text-gray-300">—</div>
        </div>
        <div class="track-line pending-line"></div>
        <div class="track-step pending-step">
          <div class="track-dot pending-dot">5</div>
          <div class="track-label text-gray-400" data-translate="track-done">Done</div>
          <div class="track-time text-xs text-gray-300">—</div>
        </div>
      </div>

      <!-- Live status card -->
      <div class="bg-gradient-to-r from-farm-50 to-soil-50 border border-farm-200 rounded-2xl p-4 flex flex-wrap items-center gap-4 mb-4">
        <div class="w-12 h-12 bg-gradient-to-br from-farm-500 to-farm-700 rounded-xl flex items-center justify-center text-white font-bold text-lg flex-shrink-0">RK</div>
        <div class="flex-1">
          <p class="font-bold text-gray-900 text-sm">Ravi Kumar <span class="text-xs text-gray-400 font-normal ml-1">⭐ 4.9</span></p>
          <p class="text-farm-700 text-sm font-medium animate-pulse-soft" data-translate="provider-on-way">🚗 Provider is on the way to your farm!</p>
          <div class="flex items-center space-x-3 mt-1">
            <span class="text-xs text-gray-500" data-translate="eta-label">ETA:</span>
            <span class="text-sm font-bold text-farm-700" id="eta-timer">45 min</span>
            <span class="text-xs text-gray-400">•</span>
            <span class="text-xs text-gray-500">12 km away</span>
          </div>
        </div>
        <div class="flex flex-col space-y-2">
          <button onclick="showToast('Calling Provider...', 'Connecting you to Ravi Kumar.', '📞')" class="flex items-center space-x-1.5 bg-white border border-gray-200 hover:border-farm-300 text-gray-700 text-xs font-semibold px-4 py-2 rounded-xl transition-all shadow-sm">
            <span>📞</span><span data-translate="contact-provider">Contact</span>
          </button>
          <button onclick="showToast('Live tracking coming soon!', 'Feature launching next month.', '🗺')" class="flex items-center space-x-1.5 bg-farm-600 text-white text-xs font-semibold px-4 py-2 rounded-xl transition-all hover:bg-farm-700">
            <span>📍</span><span data-translate="track-live">Track Live</span>
          </button>
        </div>
      </div>

      <!-- Map placeholder -->
      <div class="bg-gray-100 rounded-2xl h-32 flex items-center justify-center overflow-hidden relative border border-gray-200">
        <div class="absolute inset-0 opacity-20" style="background: repeating-linear-gradient(0deg, transparent, transparent 20px, #ccc 20px, #ccc 21px), repeating-linear-gradient(90deg, transparent, transparent 20px, #ccc 20px, #ccc 21px);"></div>
        <div class="relative text-center">
          <div class="text-3xl mb-1">🗺</div>
          <p class="text-gray-500 text-xs font-medium" data-translate="live-map-coming">Live map coming soon</p>
          <div class="mt-1 inline-flex items-center space-x-1 text-xs text-farm-600 font-semibold">
            <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
            <span>Ravi Kumar • 12 km</span>
          </div>
        </div>
      </div>

      <div class="mt-3 flex justify-end">
        <button onclick="cancelWithConfirm()" class="text-red-400 hover:text-red-600 text-xs font-medium hover:underline" data-translate="cancel-booking">Cancel Booking</button>
      </div>
    </div>

    <!-- Booking 2 — Confirmed (LABOUR) -->
    <div class="booking-track-card" data-aos="fade-up" data-aos-delay="80">
      <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
        <div class="flex items-center space-x-3">
          <div class="w-14 h-14 bg-blue-50 rounded-2xl flex items-center justify-center text-3xl">👨‍🌾</div>
          <div>
            <h4 class="font-bold text-gray-900">Kailash Patel – Labour</h4>
            <p class="text-gray-500 text-xs">April 12, 2025 • 3 days • Mehsana, Gujarat</p>
            <p class="text-farm-700 font-semibold text-sm">₹1,440 <span class="text-gray-400 font-normal text-xs">(Cash on arrival)</span></p>
          </div>
        </div>
        <div class="flex items-center space-x-2">
          <div class="status-badge status-confirmed" data-translate="status-confirmed">✅ Confirmed</div>
          <div class="text-xs text-gray-400">#FS-2025-0413</div>
        </div>
      </div>

      <!-- Progress Stepper -->
      <div class="tracking-stepper mb-4">
        <div class="track-step done-step">
          <div class="track-dot done-dot">✓</div>
          <div class="track-label" data-translate="track-booked">Booked</div>
        </div>
        <div class="track-line done-line"></div>
        <div class="track-step active-step">
          <div class="track-dot active-dot">
            <div class="w-2 h-2 bg-white rounded-full animate-pulse"></div>
          </div>
          <div class="track-label text-blue-600 font-bold" data-translate="track-confirmed">Confirmed</div>
        </div>
        <div class="track-line pending-line"></div>
        <div class="track-step pending-step">
          <div class="track-dot pending-dot">3</div>
          <div class="track-label text-gray-400" data-translate="track-on-way">On the Way</div>
        </div>
        <div class="track-line pending-line"></div>
        <div class="track-step pending-step">
          <div class="track-dot pending-dot">4</div>
          <div class="track-label text-gray-400" data-translate="track-arrived">Arrived</div>
        </div>
        <div class="track-line pending-line"></div>
        <div class="track-step pending-step">
          <div class="track-dot pending-dot">5</div>
          <div class="track-label text-gray-400" data-translate="track-done">Done</div>
        </div>
      </div>

      <div class="bg-blue-50 border border-blue-100 rounded-xl p-3 text-sm text-blue-700 flex items-center space-x-2">
        <span>📅</span>
        <span data-translate="confirmed-arrival-msg">Kailash Patel will arrive at your farm on April 12 at 7:00 AM.</span>
      </div>
      <div class="mt-3 flex justify-between items-center">
        <button onclick="showToast('Calling Kailash...', 'Connecting you to your worker.', '📞')" class="text-blue-600 text-xs font-semibold hover:underline">📞 <span data-translate="contact-worker">Contact Worker</span></button>
        <button onclick="cancelWithConfirm()" class="text-red-400 hover:text-red-600 text-xs font-medium hover:underline" data-translate="cancel-booking">Cancel</button>
      </div>
    </div>
  </section>

  <!-- ===== PAST BOOKINGS ===== -->
  <section>
    <h2 class="text-lg font-bold text-gray-900 flex items-center space-x-2 mb-4">
      <span class="text-2xl">✅</span>
      <span data-translate="past-section-title">Past Bookings</span>
    </h2>
    <div class="space-y-3">

      <!-- Past 1 -->
      <div class="past-booking-card" data-aos="fade-up">
        <div class="flex items-center space-x-3 flex-1">
          <div class="w-12 h-12 bg-farm-50 rounded-xl flex items-center justify-center text-2xl">🌾</div>
          <div class="flex-1">
            <h4 class="font-semibold text-gray-900 text-sm">Combine Harvester</h4>
            <p class="text-gray-400 text-xs">March 28 • 1 day • Rajkot</p>
            <div class="flex items-center space-x-2 mt-1">
              <span class="text-xs text-gray-500 line-through">₹2,500</span>
              <span class="text-xs font-semibold text-farm-700">Paid ₹2,500</span>
              <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded-full" data-translate="completed-badge">Completed</span>
            </div>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 mt-3 sm:mt-0">
          <button onclick="showToast('Rate submitted!', 'Thank you for your feedback.', '⭐')" class="flex items-center space-x-1 text-xs border border-soil-300 text-soil-600 hover:bg-soil-50 px-3 py-1.5 rounded-lg transition-all font-medium">
            <span>⭐</span><span data-translate="rate-btn">Rate Service</span>
          </button>
          <button onclick="addToCart('Combine Harvester', '2500')" class="flex items-center space-x-1 text-xs bg-farm-100 text-farm-700 hover:bg-farm-200 px-3 py-1.5 rounded-lg transition-all font-medium">
            <span>🔁</span><span data-translate="book-again-btn">Book Again</span>
          </button>
        </div>
      </div>

      <!-- Past 2 -->
      <div class="past-booking-card" data-aos="fade-up" data-aos-delay="60">
        <div class="flex items-center space-x-3 flex-1">
          <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center text-2xl">👨‍💼</div>
          <div class="flex-1">
            <h4 class="font-semibold text-gray-900 text-sm">Dr. Ramesh Shah – Soil Consultation</h4>
            <p class="text-gray-400 text-xs">March 20 • 45 min video call</p>
            <div class="flex items-center space-x-2 mt-1">
              <span class="text-xs font-semibold text-farm-700">Free Session</span>
              <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded-full" data-translate="completed-badge">Completed</span>
              <span class="text-soil-500 text-xs">⭐⭐⭐⭐⭐</span>
            </div>
          </div>
        </div>
        <div class="flex gap-2 mt-3 sm:mt-0">
          <button onclick="window.location.href='/consultation'" class="text-xs bg-purple-100 text-purple-700 hover:bg-purple-200 px-3 py-1.5 rounded-lg transition-all font-medium">
            🔁 <span data-translate="book-again-btn">Book Again</span>
          </button>
        </div>
      </div>

      <!-- Past 3 -->
      <div class="past-booking-card" data-aos="fade-up" data-aos-delay="120">
        <div class="flex items-center space-x-3 flex-1">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-2xl">💧</div>
          <div class="flex-1">
            <h4 class="font-semibold text-gray-900 text-sm">Power Sprayer 500L</h4>
            <p class="text-gray-400 text-xs">March 10 • 2 days • Navsari</p>
            <div class="flex items-center space-x-2 mt-1">
              <span class="text-xs font-semibold text-farm-700">Paid ₹700</span>
              <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded-full" data-translate="completed-badge">Completed</span>
            </div>
          </div>
        </div>
        <div class="flex gap-2 mt-3 sm:mt-0">
          <button onclick="showToast('Review submitted!', 'Thank you!', '⭐')" class="text-xs border border-soil-300 text-soil-600 hover:bg-soil-50 px-3 py-1.5 rounded-lg transition-all font-medium">
            ⭐ <span data-translate="rate-btn">Rate</span>
          </button>
          <button onclick="addToCart('Power Sprayer 500L', '350')" class="text-xs bg-farm-100 text-farm-700 hover:bg-farm-200 px-3 py-1.5 rounded-lg transition-all font-medium">
            🔁 <span data-translate="book-again-btn">Book Again</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Empty state if no bookings at all -->
  <section class="hidden text-center py-16" id="empty-bookings">
    <div class="text-7xl mb-4">📭</div>
    <h3 class="text-2xl font-bold text-gray-700 mb-2" data-translate="no-bookings">No bookings yet</h3>
    <p class="text-gray-400 mb-6" data-translate="no-bookings-desc">Book your first service and it will appear here.</p>
    <a href="/equipment" class="inline-flex items-center space-x-2 bg-farm-600 text-white font-bold px-7 py-3.5 rounded-2xl hover:bg-farm-700 transition-colors shadow-lg">
      <span>🚜</span><span data-translate="browse-now">Browse Services Now</span>
    </a>
  </section>

</div>

<%- include('partials/footer') %>

<script>
  // ETA countdown
  let etaMinutes = 45;
  const etaTimer = document.getElementById('eta-timer');
  if (etaTimer) {
    setInterval(() => {
      if (etaMinutes > 1) {
        etaMinutes--;
        etaTimer.textContent = etaMinutes + ' min';
      } else {
        etaTimer.textContent = 'Arriving now!';
        etaTimer.classList.add('text-green-600');
      }
    }, 15000); // updates every 15s for demo purposes
  }

  // Cart count in header
  let cartCount = 1;
  updateCartBadge(cartCount);

  function removeCartItem(id) {
    document.getElementById(id).style.opacity = '0.5';
    document.getElementById(id).style.transform = 'scale(0.95)';
    setTimeout(() => {
      document.getElementById(id).remove();
      cartCount = Math.max(0, cartCount - 1);
      updateCartBadge(cartCount);
      document.getElementById('cart-items-count').textContent = cartCount + ' item' + (cartCount !== 1 ? 's' : '');
      if (cartCount === 0) {
        document.getElementById('empty-cart').classList.remove('hidden');
      }
    }, 300);
    showToast('Removed from cart', 'Item removed successfully.', '🗑');
  }

  function confirmCartItem(id, name, amount) {
    const btn = event.target;
    btn.textContent = 'Confirming...';
    btn.disabled = true;
    setTimeout(() => {
      removeCartItem(id);
      showToast('Booking Confirmed! 🎉', name + ' has been booked successfully.', '✅');
      document.getElementById('active-count').textContent = parseInt(document.getElementById('active-count').textContent) + 1;
    }, 900);
  }

  function addToCart(name, price) {
    cartCount++;
    updateCartBadge(cartCount);
    document.getElementById('cart-items-count').textContent = cartCount + ' item' + (cartCount !== 1 ? 's' : '');
    document.getElementById('empty-cart').classList.add('hidden');

    const item = document.createElement('div');
    item.className = 'cart-item-card animate-bounce-in';
    item.id = 'cart-new-' + Date.now();
    const id = item.id;
    item.innerHTML = `
      <div class="flex items-center space-x-4">
        <div class="w-14 h-14 bg-amber-50 rounded-2xl flex items-center justify-center text-3xl flex-shrink-0">🚜</div>
        <div class="flex-1">
          <div class="flex items-start justify-between">
            <div>
              <h4 class="font-bold text-gray-900 text-sm">${name}</h4>
              <p class="text-gray-500 text-xs mt-0.5">📍 Your location • Select dates</p>
            </div>
            <div class="text-right">
              <div class="font-bold text-farm-700">₹${parseInt(price).toLocaleString('en-IN')}</div>
              <div class="text-gray-400 text-xs">per day</div>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-3 pt-3 border-t border-gray-100 flex items-center justify-between">
        <span class="text-xs text-gray-400">💳 Cash on arrival</span>
        <div class="flex space-x-2">
          <button onclick="removeCartItem('${id}')" class="text-red-400 hover:text-red-600 border border-red-200 text-xs font-medium px-3 py-1.5 rounded-lg">Remove</button>
          <button onclick="confirmCartItem('${id}', '${name}', '${price}')" class="bg-farm-600 hover:bg-farm-700 text-white text-xs font-bold px-4 py-1.5 rounded-lg">Confirm Booking</button>
        </div>
      </div>`;
    document.getElementById('cart-list').appendChild(item);
    showToast(name + ' added to cart!', 'Go to My Bookings to confirm.', '🛒');
  }

  function cancelWithConfirm() {
    if (confirm('Are you sure you want to cancel this booking? Cancellation charges may apply.')) {
      showToast('Booking Cancelled', 'Your booking has been cancelled. Refund in 3-5 days.', '❌');
    }
  }

  function updateCartBadge(count) {
    const badge = document.getElementById('cart-badge');
    if (!badge) return;
    if (count > 0) {
      badge.textContent = count;
      badge.classList.remove('hidden');
      badge.classList.add('flex');
    } else {
      badge.classList.add('hidden');
      badge.classList.remove('flex');
    }
  }
</script>
