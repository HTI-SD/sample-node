          <div class="w-14 h-14 bg-amber-50 rounded-2xl flex items-center justify-center text-3xl flex-shrink-0">🌱</div>
          <div class="flex-1">
            <div class="flex items-start justify-between">
              <div>
                <h4 class="font-bold text-gray-900 text-sm">Seed Drill (9 Row)</h4>
                <p class="text-gray-500 text-xs mt-0.5">📍 Ahmedabad • April 14 • 2 days</p>
              </div>
              <div class="text-right">
                <div class="font-bold text-farm-700">₹600</div>
                <div class="text-gray-400 text-xs">₹300 × 2 days</div>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-3 pt-3 border-t border-gray-100 flex items-center justify-between">
          <div class="flex items-center space-x-1 text-xs text-gray-400">
            <span>💳</span>
            <span data-translate="pay-on-arrival">Cash on arrival</span>
          </div>
          <div class="flex space-x-2">
            <button onclick="removeCartItem('cart-item-1')" class="text-red-400 hover:text-red-600 border border-red-200 hover:border-red-400 text-xs font-medium px-3 py-1.5 rounded-lg transition-colors" data-translate="remove-btn">Remove</button>
            <button onclick="confirmCartItem('cart-item-1', 'Seed Drill (9 Row)', '600')" class="bg-farm-600 hover:bg-farm-700 text-white text-xs font-bold px-4 py-1.5 rounded-lg transition-colors" data-translate="confirm-btn">Confirm Booking</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Empty cart state (hidden by default) -->
    <div id="empty-cart" class="hidden text-center py-8 bg-gray-50 rounded-2xl border border-dashed border-gray-200">
      <div class="text-5xl mb-3">🛒</div>
      <p class="text-gray-500 font-medium" data-translate="empty-cart">Your cart is empty</p>
      <a href="/equipment" class="inline-block mt-3 text-farm-600 font-semibold text-sm hover:underline" data-translate="browse-services">Browse Services →</a>
    </div>
  </section>

  <!-- ===== ACTIVE BOOKINGS ===== -->
