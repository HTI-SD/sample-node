<%- include('partials/header', { title: 'My Bookings – FarmSeva', activePage: 'bookings' }) %>

<div class="bg-gradient-to-r from-gray-800 to-gray-700 py-10 px-4">
  <div class="max-w-5xl mx-auto flex flex-wrap items-end gap-4">
    <div>
      <p class="text-gray-400 text-sm mb-1">Welcome back 👋</p>
      <h1 class="text-3xl font-bold text-white" data-translate="page-my-bookings">My Bookings</h1>
      <p class="text-gray-300 text-sm mt-1" data-translate="page-my-bookings-desc">Track all your service bookings and orders in one place.</p>
    </div>
    <div class="ml-auto flex space-x-3">
      <div class="bg-white/10 border border-white/20 rounded-xl px-4 py-2 text-center">
        <div class="text-xl font-bold text-white" id="active-count">2</div>
        <div class="text-gray-300 text-xs" data-translate="active-label">Active</div>
      </div>
      <div class="bg-white/10 border border-white/20 rounded-xl px-4 py-2 text-center">
        <div class="text-xl font-bold text-white">1</div>
        <div class="text-gray-300 text-xs" data-translate="cart-label">In Cart</div>
      </div>
      <div class="bg-white/10 border border-white/20 rounded-xl px-4 py-2 text-center">
        <div class="text-xl font-bold text-white">3</div>
        <div class="text-gray-300 text-xs" data-translate="completed-label">Completed</div>
      </div>
    </div>
  </div>
</div>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-10">

  <!-- ===== CART (Pending Confirmation) ===== -->
  <section id="cart-section">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold text-gray-900 flex items-center space-x-2">
        <span class="text-2xl">🛒</span>
        <span data-translate="cart-section-title">Cart — Pending Confirmation</span>
        <span class="bg-gray-200 text-gray-600 text-xs px-2 py-0.5 rounded-full font-bold" id="cart-items-count">1 item</span>
      </h2>
    </div>

    <div class="space-y-3" id="cart-list">
      <!-- Cart item 1 -->
      <div class="cart-item-card" id="cart-item-1">
