<!-- Consultation Modal -->
<div id="consult-modal" class="modal-overlay hidden">
  <div class="modal-box max-w-md w-full mx-4">
    <div class="modal-header">
      <h3 class="text-xl font-bold text-gray-900">Book Consultation</h3>
      <button onclick="closeConsultModal()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
    </div>
    <div class="p-5 space-y-4">
      <div class="bg-purple-50 border border-purple-200 rounded-xl p-3 flex items-center space-x-3">
        <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-purple-700 rounded-xl flex items-center justify-center text-white font-bold" id="cm-avatar">RS</div>
        <div>
          <div class="font-semibold text-gray-900 text-sm" id="cm-name">Dr. Ramesh Shah</div>
          <div class="text-xs text-gray-500" id="cm-spec">Soil Testing</div>
          <div class="text-green-600 font-bold text-sm">First session FREE 🎁</div>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="modal-label">Preferred Date</label>
          <input type="date" id="cm-date" class="modal-input">
        </div>
        <div>
          <label class="modal-label">Time Slot</label>
          <select class="modal-input">
            <option>9:00 AM</option>
            <option>10:00 AM</option>
            <option>11:00 AM</option>
            <option>2:00 PM</option>
            <option>3:00 PM</option>
            <option>4:00 PM</option>
          </select>
        </div>
      </div>
      <div>
        <label class="modal-label">Consultation Mode</label>
        <div class="grid grid-cols-2 gap-2">
          <label class="payment-option"><input type="radio" name="mode" value="call" class="hidden" checked><span class="payment-label active-payment">📞 Phone Call</span></label>
          <label class="payment-option"><input type="radio" name="mode" value="video" class="hidden"><span class="payment-label">📹 Video Call</span></label>
        </div>
      </div>
      <div>
        <label class="modal-label">Your Question / Issue</label>
        <textarea placeholder="Describe your crop problem, soil condition, or what advice you need..." rows="3" class="modal-input resize-none"></textarea>
      </div>
      <div>
        <label class="modal-label">Your Mobile</label>
        <input type="tel" placeholder="+91 98765 43210" class="modal-input">
      </div>
    </div>
    <div class="px-5 pb-5">
      <button onclick="confirmConsult()" class="w-full bg-gradient-to-r from-purple-600 to-purple-700 hover:from-purple-700 hover:to-purple-800 text-white font-bold py-3.5 rounded-xl transition-all shadow-lg">
        ✅ Schedule Consultation
      </button>
      <p class="text-green-600 text-xs text-center mt-2 font-medium">🎁 First 30-minute session is completely free!</p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  function filterExpert(type, btn) {
    document.querySelectorAll('.expert-tab').forEach(b => b.classList.remove('active-expert-tab'));
    btn.classList.add('active-expert-tab');
    document.querySelectorAll('.expert-card').forEach(card => {
      const t = card.dataset.type || '';
      card.classList.toggle('hidden', type !== 'all' && !t.includes(type));
    });
  }

  function openConsultModal(name, price, spec) {
    document.getElementById('cm-name').textContent = name;
    document.getElementById('cm-spec').textContent = spec;
    document.getElementById('cm-avatar').textContent = name.replace('Dr. ', '').split(' ').map(w => w[0]).join('').slice(0, 2);
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('cm-date').value = today;
    document.getElementById('cm-date').min = today;
    document.getElementById('consult-modal').classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
  }

  function closeConsultModal() {
    document.getElementById('consult-modal').classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }

  function confirmConsult() {
    closeConsultModal();
    showToast('Consultation Booked!', 'Expert will call you at the selected time.', '📞');
  }

  document.querySelectorAll('input[name="mode"]').forEach(r => {
    r.addEventListener('change', () => {
      document.querySelectorAll('.payment-label').forEach(l => l.classList.remove('active-payment'));
      r.nextElementSibling.classList.add('active-payment');
    });
  });

  document.getElementById('consult-modal').addEventListener('click', e => {
    if (e.target === e.currentTarget) closeConsultModal();
  });
</script>
