<%- include('partials/header', { title: 'Group Booking – FarmSeva', activePage: 'group' }) %>

<div class="bg-gradient-to-r from-soil-700 to-soil-500 py-12 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-center space-x-2 text-soil-300 text-sm mb-3">
      <a href="/" class="hover:text-white">Home</a><span>/</span>
      <span class="text-white">Group Booking</span>
    </div>
    <div class="flex items-center space-x-3">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">👥 Group Booking</h1>
      <span class="bg-white text-soil-700 text-sm px-3 py-1 rounded-full font-bold">Save up to 40%</span>
    </div>
    <p class="text-soil-200">Join other farmers, share equipment cost, and everyone saves together. Strength in numbers!</p>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <!-- How it saves money banner -->
  <div class="bg-gradient-to-r from-farm-600 to-farm-800 rounded-2xl p-5 mb-8 text-white flex flex-wrap items-center gap-5" data-aos="fade-up">
    <div class="flex items-center space-x-3">
      <span class="text-5xl">💰</span>
      <div>
        <p class="font-bold text-lg">Savings Example</p>
        <p class="text-farm-200 text-sm">Harvester: ₹2,500/day</p>
      </div>
    </div>
    <div class="flex items-center space-x-3 flex-1 justify-center">
      <div class="text-center">
        <div class="text-3xl font-bold text-red-300">₹2,500</div>
        <div class="text-farm-300 text-xs">1 farmer alone</div>
      </div>
      <div class="text-3xl">→</div>
      <div class="text-center">
        <div class="text-3xl font-bold text-soil-300">₹500</div>
        <div class="text-farm-300 text-xs">per farmer in group of 5</div>
      </div>
      <div class="bg-soil-400 rounded-xl px-3 py-1 text-soil-900 font-bold text-sm">SAVE ₹2,000!</div>
    </div>
    <a href="#create-group" class="bg-white text-farm-700 font-bold px-5 py-2.5 rounded-xl hover:bg-farm-50 transition-colors text-sm">
      Start a Group
    </a>
  </div>

  <div class="grid lg:grid-cols-3 gap-7">

    <!-- Active Groups -->
    <div class="lg:col-span-2">
      <h3 class="text-xl font-bold text-gray-900 mb-5" data-aos="fade-up">🔥 Active Groups Near You</h3>

      <div class="space-y-5" id="groups-list">

        <!-- Group 1 -->
        <div class="group-card" data-aos="fade-up" data-aos-delay="0">
          <div class="flex items-start justify-between mb-3">
            <div class="flex items-center space-x-3">
              <div class="w-12 h-12 bg-amber-100 rounded-2xl flex items-center justify-center text-2xl">🚜</div>
              <div>
                <h4 class="font-bold text-gray-900">Tractor Group – Anand Area</h4>
                <p class="text-gray-500 text-xs">Mahindra 45HP • April 8, 2025</p>
              </div>
            </div>
            <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-bold">2 Spots Left</span>
          </div>

          <!-- Member slots -->
          <div class="flex items-center space-x-2 mb-3">
            <div class="group-member-slot filled">👨‍🌾</div>
            <div class="group-member-slot filled">👩‍🌾</div>
            <div class="group-member-slot filled">🧑‍🌾</div>
            <div class="group-member-slot empty">?</div>
            <div class="group-member-slot empty">?</div>
            <span class="text-sm text-gray-500 ml-2">3/5 joined</span>
          </div>

          <!-- Progress bar -->
          <div class="mb-3">
            <div class="flex justify-between text-xs text-gray-500 mb-1">
              <span>Group filling up...</span>
              <span class="text-farm-600 font-semibold">3 of 5 farmers joined</span>
            </div>
            <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-farm-500 to-farm-600 rounded-full" style="width:60%"></div>
            </div>
          </div>

          <div class="flex items-center justify-between pt-3 border-t border-gray-100">
            <div>
              <span class="text-gray-400 text-xs line-through">₹800/day</span>
              <span class="text-xl font-bold text-farm-700 ml-2">₹160</span>
              <span class="text-gray-400 text-xs">/farmer/day</span>
              <span class="ml-2 text-green-600 text-xs font-semibold">80% savings!</span>
            </div>
            <button onclick="joinGroup('Tractor Group – Anand Area', '160')" class="book-btn">Join Group</button>
          </div>
        </div>

        <!-- Group 2 -->
        <div class="group-card" data-aos="fade-up" data-aos-delay="80">
          <div class="flex items-start justify-between mb-3">
            <div class="flex items-center space-x-3">
              <div class="w-12 h-12 bg-farm-100 rounded-2xl flex items-center justify-center text-2xl">🌾</div>
              <div>
                <h4 class="font-bold text-gray-900">Harvester Share – Vadodara</h4>
                <p class="text-gray-500 text-xs">Combine Harvester • April 12, 2025</p>
              </div>
            </div>
            <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full font-bold">1 Spot Left</span>
          </div>
          <div class="flex items-center space-x-2 mb-3">
            <div class="group-member-slot filled">👨‍🌾</div>
            <div class="group-member-slot filled">👩‍🌾</div>
            <div class="group-member-slot filled">🧑‍🌾</div>
            <div class="group-member-slot filled">👨‍🌾</div>
            <div class="group-member-slot empty">?</div>
            <span class="text-sm text-gray-500 ml-2">4/5 joined</span>
          </div>
          <div class="mb-3">
            <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-soil-400 to-soil-500 rounded-full" style="width:80%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between pt-3 border-t border-gray-100">
            <div>
              <span class="text-gray-400 text-xs line-through">₹2,500/day</span>
              <span class="text-xl font-bold text-farm-700 ml-2">₹500</span>
              <span class="text-gray-400 text-xs">/farmer/day</span>
              <span class="ml-2 text-green-600 text-xs font-semibold">Save ₹2,000!</span>
            </div>
            <button onclick="joinGroup('Harvester Share – Vadodara', '500')" class="book-btn">Join Group</button>
          </div>
        </div>

        <!-- Group 3 -->
        <div class="group-card opacity-70" data-aos="fade-up" data-aos-delay="160">
          <div class="flex items-start justify-between mb-3">
            <div class="flex items-center space-x-3">
              <div class="w-12 h-12 bg-blue-100 rounded-2xl flex items-center justify-center text-2xl">🚁</div>
              <div>
                <h4 class="font-bold text-gray-900">Drone Spray Group – Rajkot</h4>
                <p class="text-gray-500 text-xs">Agri Drone • April 10, 2025</p>
              </div>
            </div>
            <span class="text-xs bg-gray-200 text-gray-600 px-2 py-0.5 rounded-full font-bold">Full</span>
          </div>
          <div class="flex items-center space-x-2 mb-3">
            <div class="group-member-slot filled">👨‍🌾</div>
            <div class="group-member-slot filled">👩‍🌾</div>
            <div class="group-member-slot filled">🧑‍🌾</div>
            <div class="group-member-slot filled">👨‍🌾</div>
            <div class="group-member-slot filled">👩‍🌾</div>
            <span class="text-sm text-gray-500 ml-2">5/5 joined ✓</span>
          </div>
          <div class="mb-3">
            <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
              <div class="h-full bg-gray-400 rounded-full" style="width:100%"></div>
            </div>
          </div>
          <div class="pt-3 border-t border-gray-100">
            <span class="text-gray-400 text-sm">Group full. Join waitlist to be notified next time.</span>
            <button onclick="showToast('Added to Waitlist', 'You will be notified when a spot opens.', '🔔')" class="ml-3 text-farm-600 text-sm font-semibold hover:underline">Join Waitlist</button>
          </div>
        </div>

      </div>
    </div>

    <!-- Create Group Panel -->
    <div id="create-group" data-aos="fade-left">
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 sticky top-20">
        <h3 class="font-bold text-gray-900 text-lg mb-1">➕ Start a New Group</h3>
        <p class="text-gray-500 text-sm mb-5">Create a group and invite nearby farmers to share equipment cost.</p>

        <div class="space-y-4">
          <div>
            <label class="modal-label">Equipment Type</label>
            <select class="modal-input" id="gc-equip">
              <option>🚜 Tractor (₹800/day)</option>
              <option>🌾 Combine Harvester (₹2,500/day)</option>
              <option>🚁 Agri Drone (₹1,200/day)</option>
              <option>⚙️ Rotavator (₹400/day)</option>
              <option>🌱 Seed Drill (₹300/day)</option>
            </select>
          </div>

          <div>
            <label class="modal-label">Date Needed</label>
            <input type="date" id="gc-date" class="modal-input">
          </div>

          <div>
            <label class="modal-label">Group Size</label>
            <div class="grid grid-cols-4 gap-2">
              <button onclick="selectGroupSize(this, 3)" class="group-size-btn">3</button>
              <button onclick="selectGroupSize(this, 4)" class="group-size-btn">4</button>
              <button onclick="selectGroupSize(this, 5)" class="group-size-btn active-group-size">5</button>
              <button onclick="selectGroupSize(this, 8)" class="group-size-btn">8</button>
            </div>
          </div>

          <div>
            <label class="modal-label">Your Village / Area</label>
            <input type="text" placeholder="e.g. Borsad Taluka, Anand" class="modal-input">
          </div>

          <div>
            <label class="modal-label">Your Mobile</label>
            <input type="tel" placeholder="+91 98765 43210" class="modal-input">
          </div>

          <!-- Savings preview -->
          <div class="bg-farm-50 border border-farm-200 rounded-xl p-3 text-center">
            <p class="text-farm-700 text-xs font-semibold mb-1">💰 Estimated Savings Per Person</p>
            <p class="text-2xl font-bold text-farm-700" id="savings-preview">₹160/day</p>
            <p class="text-farm-500 text-xs">vs ₹800 alone → Save 80%</p>
          </div>

          <button onclick="createGroup()" class="w-full bg-gradient-to-r from-soil-600 to-soil-700 hover:from-soil-700 hover:to-soil-800 text-white font-bold py-3.5 rounded-xl transition-all shadow-lg">
            🤝 Create Group Now
          </button>
          <p class="text-gray-400 text-xs text-center">Nearby farmers will be notified immediately</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Join Group Modal -->
<div id="join-modal" class="modal-overlay hidden">
  <div class="modal-box max-w-sm w-full mx-4">
    <div class="modal-header">
      <h3 class="text-xl font-bold text-gray-900">Join Group</h3>
      <button onclick="closeJoinModal()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
    </div>
    <div class="p-5 space-y-4">
      <div class="bg-soil-50 border border-soil-200 rounded-xl p-3">
        <p class="font-semibold text-gray-900 text-sm" id="join-group-name">Tractor Group</p>
        <p class="text-farm-600 font-bold" id="join-group-price">₹160/day per farmer</p>
      </div>
      <div>
        <label class="modal-label">Your Name</label>
        <input type="text" placeholder="Ramesh Patel" class="modal-input">
      </div>
      <div>
        <label class="modal-label">Mobile Number</label>
        <input type="tel" placeholder="+91 98765 43210" class="modal-input">
      </div>
      <div>
        <label class="modal-label">Farm Size (acres)</label>
        <input type="number" placeholder="e.g. 3" class="modal-input" min="0.5" step="0.5">
      </div>
    </div>
    <div class="px-5 pb-5">
      <button onclick="confirmJoin()" class="w-full bg-gradient-to-r from-soil-600 to-soil-700 text-white font-bold py-3.5 rounded-xl transition-all shadow-lg">
        ✅ Confirm & Join Group
      </button>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  let groupSize = 5;
  const equipPrices = { 0: 800, 1: 2500, 2: 1200, 3: 400, 4: 300 };

  document.getElementById('gc-date').min = new Date().toISOString().split('T')[0];
  document.getElementById('gc-date').value = new Date().toISOString().split('T')[0];

  function selectGroupSize(btn, size) {
    document.querySelectorAll('.group-size-btn').forEach(b => b.classList.remove('active-group-size'));
    btn.classList.add('active-group-size');
    groupSize = size;
    updateSavings();
  }

  function updateSavings() {
    const equipIdx = document.getElementById('gc-equip').selectedIndex;
    const price = equipPrices[equipIdx] || 800;
    const perPerson = Math.round(price / groupSize);
    const saving = Math.round((1 - 1/groupSize) * 100);
    document.getElementById('savings-preview').textContent = '₹' + perPerson.toLocaleString('en-IN') + '/day';
    document.querySelector('#create-group .text-farm-500').textContent = `vs ₹${price} alone → Save ${saving}%`;
  }

  document.getElementById('gc-equip').addEventListener('change', updateSavings);

  function joinGroup(name, price) {
    document.getElementById('join-group-name').textContent = name;
    document.getElementById('join-group-price').textContent = '₹' + parseInt(price).toLocaleString('en-IN') + '/day per farmer';
    document.getElementById('join-modal').classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
  }

  function closeJoinModal() {
    document.getElementById('join-modal').classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }

  function confirmJoin() {
    closeJoinModal();
    showToast('Joined Group! 🎉', 'You have been added to the group. Others will be notified.', '✅');
  }

  function createGroup() {
    showToast('Group Created!', 'Nearby farmers have been notified. Waiting for members to join.', '👥');
  }

  document.getElementById('join-modal').addEventListener('click', e => {
    if (e.target === e.currentTarget) closeJoinModal();
  });
</script>
