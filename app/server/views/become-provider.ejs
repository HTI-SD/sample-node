<script>
  let currentStep = 1;

  // Service type card toggle
  document.querySelectorAll('.service-checkbox').forEach(cb => {
    cb.addEventListener('change', () => {
      const card = cb.closest('label').querySelector('.service-type-card');
      card.classList.toggle('selected-service-type', cb.checked);
    });
  });

  // Click on card toggles checkbox
  document.querySelectorAll('.service-type-card').forEach(card => {
    card.addEventListener('click', () => {
      const cb = card.closest('label').querySelector('.service-checkbox');
      cb.checked = !cb.checked;
      card.classList.toggle('selected-service-type', cb.checked);
    });
  });

  function goToStep(n) {
    // Validate step 1
    if (n === 2) {
      const checked = document.querySelectorAll('.service-checkbox:checked');
      if (checked.length === 0) {
        showToast('Select at least one service', 'Please pick what you will offer.', '⚠️');
        return;
      }
    }

    document.getElementById('step-content-' + currentStep).classList.add('hidden');
    currentStep = n;
    document.getElementById('step-content-' + currentStep).classList.remove('hidden');

    // Update step bar
    for (let i = 1; i <= 4; i++) {
      const el = document.getElementById('pstep-' + i);
      const conn = document.getElementById('pconn-' + (i-1));
      if (i < n) {
        el.classList.remove('active-provider-step');
        el.classList.add('done-provider-step');
        el.querySelector('span').textContent = '✓';
        if (conn) conn.classList.add('done-connector');
      } else if (i === n) {
        el.classList.add('active-provider-step');
        el.classList.remove('done-provider-step');
      } else {
        el.classList.remove('active-provider-step','done-provider-step');
        el.querySelector('span').textContent = i;
      }
    }
  }

  // ─── Google OAuth mock ────────────────────────────────
  let _googleSigninBtn = null;

  function handleGoogleSignup() {
    _googleSigninBtn = event.target.closest('button');
    document.getElementById('google-picker-modal').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeGoogleModal() {
    document.getElementById('google-picker-modal').classList.add('hidden');
    document.body.style.overflow = '';
  }

  function selectGoogleAccount() {
    closeGoogleModal();

    // Show "signing in" state on the Google button
    if (_googleSigninBtn) {
      _googleSigninBtn.disabled = true;
      _googleSigninBtn.innerHTML = `
        <svg class="w-4 h-4 animate-spin mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
        </svg>
        <span>Signing in as <strong>Ramesh Kumar</strong>...</span>`;
    }

    // After brief delay: pre-fill profile form, show signed-in banner, go to step 4
    setTimeout(() => {
      // Pre-fill name from Google account
      const nameInput = document.getElementById('provider-name');
      if (nameInput) nameInput.value = 'Ramesh Kumar';

      goToStep(4);

      // Reveal the "signed in via Google" info banner in step 4
      const banner = document.getElementById('google-signed-in-info');
      if (banner) banner.classList.remove('hidden');

      showToast('Google Sign-in Successful! ✓', 'Welcome, Ramesh Kumar. Complete your provider profile.', '🎉');
    }, 1600);
  }

  function sendOTP() {
    const mobile = document.getElementById('provider-mobile').value.trim();
    if (mobile.length < 10) {
      showToast('Enter valid mobile number', 'Please enter a 10-digit number.', '⚠️');
      return;
    }
    document.getElementById('otp-mobile-display').textContent = '+91 ' + mobile;
    goToStep(3);
    showToast('OTP Sent!', 'SMS sent to +91 ' + mobile + '. Use 1 2 3 4 5 6 for demo.', '📱');
    // Auto-fill OTP for demo
    setTimeout(() => {
      ['1','2','3','4','5','6'].forEach((d,i) => {
        document.getElementById('otp-' + i).value = d;
      });
    }, 800);
  }

  function otpAutoAdvance(input, idx) {
    if (input.value.length === 1 && idx < 5) {
      document.getElementById('otp-' + (idx + 1)).focus();
    }
  }

  function verifyOTP() {
    const code = Array.from({length:6}, (_,i) => document.getElementById('otp-'+i).value).join('');
    if (code.length < 6) { showToast('Enter full OTP', 'Please enter all 6 digits.', '⚠️'); return; }
    const btn = document.getElementById('verify-btn');
    btn.textContent = 'Verifying...';
    btn.disabled = true;
    setTimeout(() => goToStep(4), 1200);
  }

  function submitProfile() {
    showToast('Profile Submitted!', 'We will review and activate your account within 24 hours.', '🎉');
    setTimeout(() => {
      document.getElementById('step-content-4').classList.add('hidden');
      document.getElementById('step-content-5').classList.remove('hidden');
      document.getElementById('step-bar').classList.add('hidden');
      animateEarnings();
    }, 800);
  }

  function animateEarnings() {
    const counter = document.getElementById('earn-counter');
    if (!counter) return;
    let val = 0;
    const target = 500;
    const stepSize = target / (1500 / 16);
    const timer = setInterval(() => {
      val = Math.min(val + stepSize, target);
      counter.textContent = Math.round(val).toLocaleString('en-IN');
      if (val >= target) {
        clearInterval(timer);
        counter.textContent = '500';
        showToast('₹500 Credited! 💰', 'Welcome bonus added to your FarmSeva wallet.', '💰');
        setTimeout(() => {
          const notif = document.getElementById('fake-booking-notif');
          if (notif) {
            notif.classList.remove('hidden');
            showToast('New Booking Request!', 'Ramesh Patel wants your Tractor — ₹1,200', '🚜');
          }
        }, 3000);
      }
    }, 16);
  }

  function acceptDemoBooking() {
    document.getElementById('fake-booking-notif').classList.add('hidden');
    document.getElementById('booking-accepted-state').classList.remove('hidden');
    showToast('Booking Accepted! 🎉', '₹1,200 will be credited after service. Total: ₹1,700', '✅');
  }
</script>
