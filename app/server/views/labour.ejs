<!-- Labour Booking Modal -->
<div id="labour-modal" class="modal-overlay hidden">
  <div class="modal-box max-w-md w-full mx-4">
    <div class="modal-header">
      <h3 class="text-xl font-bold text-gray-900">Book Worker</h3>
      <button onclick="closeLabourModal()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
    </div>

    <div class="p-5 space-y-4">
      <div class="bg-blue-50 border border-blue-200 rounded-xl p-3 flex items-center space-x-3">
        <div class="w-10 h-10 bg-gradient-to-br from-blue-400 to-blue-600 rounded-full flex items-center justify-center text-white font-bold text-sm" id="lm-avatar">RP</div>
        <div>
          <div class="font-semibold text-gray-900 text-sm" id="lm-name">Rajesh Patel</div>
          <div class="text-xs text-gray-500" id="lm-skills">Harvesting, Sowing</div>
          <div class="text-farm-600 font-bold text-sm" id="lm-price">₹450/day</div>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="modal-label">Start Date</label>
          <input type="date" id="lm-start" class="modal-input">
        </div>
        <div>
          <label class="modal-label">No. of Days</label>
          <select id="lm-days" class="modal-input" onchange="updateLabourTotal()">
            <option value="1">1 Day</option>
            <option value="2">2 Days</option>
            <option value="3">3 Days</option>
            <option value="5">5 Days</option>
            <option value="7">7 Days</option>
          </select>
        </div>
      </div>

      <div>
        <label class="modal-label">Task Description</label>
        <textarea placeholder="e.g. Wheat harvesting on 3 acre field..." rows="2" class="modal-input resize-none"></textarea>
      </div>
      <div>
        <label class="modal-label">Your Mobile Number</label>
        <input type="tel" placeholder="+91 98765 43210" class="modal-input">
      </div>
      <div>
        <label class="modal-label">Farm Location</label>
        <input type="text" placeholder="Village name, Taluka" class="modal-input">
      </div>

      <div class="bg-gray-50 rounded-xl p-3 flex justify-between items-center border border-gray-200">
        <span class="text-gray-600 text-sm font-medium">Total Amount</span>
        <span class="text-xl font-bold text-farm-700" id="lm-total">₹450</span>
      </div>
    </div>

    <div class="px-5 pb-5">
      <button onclick="confirmLabour()" class="w-full bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-bold py-3.5 rounded-xl transition-all shadow-lg">
        ✅ Confirm Booking
      </button>
      <p class="text-gray-400 text-xs text-center mt-2">Worker will be notified immediately via SMS.</p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  let labourPrice = 450;

  function filterBySkill(skill) {
    document.querySelectorAll('.skill-filter-btn').forEach(b => b.classList.remove('active-skill-btn'));
    event.target.classList.add('active-skill-btn');

    const cards = document.querySelectorAll('.worker-card');
    let visible = 0;
    cards.forEach(card => {
      const skills = card.dataset.skill || '';
      if (skill === 'all' || skills.includes(skill)) {
        card.classList.remove('hidden');
        visible++;
      } else {
        card.classList.add('hidden');
      }
    });
    document.getElementById('labour-count').textContent = visible + ' worker' + (visible !== 1 ? 's' : '');
  }

  function openLabourModal(name, price, skills) {
    labourPrice = parseInt(price);
    document.getElementById('lm-name').textContent = name;
    document.getElementById('lm-skills').textContent = skills;
    document.getElementById('lm-price').textContent = '₹' + parseInt(price).toLocaleString('en-IN') + '/day';
    document.getElementById('lm-total').textContent = '₹' + parseInt(price).toLocaleString('en-IN');
    document.getElementById('lm-avatar').textContent = name.split(' ').map(w => w[0]).join('').slice(0, 2);
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('lm-start').value = today;
    document.getElementById('lm-start').min = today;
    document.getElementById('labour-modal').classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
  }

  function closeLabourModal() {
    document.getElementById('labour-modal').classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }

  function updateLabourTotal() {
    const days = parseInt(document.getElementById('lm-days').value);
    document.getElementById('lm-total').textContent = '₹' + (labourPrice * days).toLocaleString('en-IN');
  }

  function confirmLabour() {
    closeLabourModal();
    showToast('Worker Booked! 👷', 'Worker will arrive at your farm on the selected date.', '✅');
  }

  document.getElementById('labour-modal').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeLabourModal();
  });
</script>
