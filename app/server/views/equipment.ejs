<!-- ===== BOOKING MODAL ===== -->
<div id="booking-modal" class="modal-overlay hidden">
  <div class="modal-box max-w-md w-full mx-4">
    <div class="modal-header">
      <h3 class="text-xl font-bold text-gray-900" id="modal-title">Book Equipment</h3>
      <button onclick="closeBookingModal()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
    </div>

    <div class="p-5 space-y-4">
      <!-- Equipment name -->
      <div class="bg-farm-50 border border-farm-200 rounded-xl p-3 flex items-center space-x-3">
        <span class="text-3xl">🚜</span>
        <div>
          <div class="font-semibold text-gray-900 text-sm" id="modal-equip-name">Mahindra Tractor</div>
          <div class="text-farm-600 font-bold" id="modal-equip-price">₹800/day</div>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="modal-label">Start Date</label>
          <input type="date" id="book-start" class="modal-input" min="">
        </div>
        <div>
          <label class="modal-label">No. of Days</label>
          <select id="book-days" class="modal-input" onchange="updateTotal()">
            <option value="1">1 Day</option>
            <option value="2">2 Days</option>
            <option value="3">3 Days</option>
            <option value="5">5 Days</option>
            <option value="7">7 Days</option>
          </select>
        </div>
      </div>

      <div>
        <label class="modal-label">Your Name</label>
        <input type="text" placeholder="Ramesh Patel" class="modal-input">
      </div>
      <div>
        <label class="modal-label">Mobile Number</label>
        <input type="tel" placeholder="+91 98765 43210" class="modal-input">
      </div>
      <div>
        <label class="modal-label">Village / Farm Location</label>
        <input type="text" placeholder="Village name, Taluka" class="modal-input">
      </div>

      <div>
        <label class="modal-label">Payment Method</label>
        <div class="grid grid-cols-3 gap-2">
          <label class="payment-option"><input type="radio" name="payment" value="cash" class="hidden" checked><span class="payment-label active-payment" id="pay-cash">💵 Cash</span></label>
          <label class="payment-option"><input type="radio" name="payment" value="upi" class="hidden"><span class="payment-label" id="pay-upi">📱 UPI</span></label>
          <label class="payment-option"><input type="radio" name="payment" value="card" class="hidden"><span class="payment-label" id="pay-card">💳 Card</span></label>
        </div>
      </div>

      <!-- Total -->
      <div class="bg-gray-50 rounded-xl p-3 flex justify-between items-center border border-gray-200">
        <span class="text-gray-600 text-sm font-medium">Total Amount</span>
        <span class="text-xl font-bold text-farm-700" id="modal-total">₹800</span>
      </div>
    </div>

    <div class="px-5 pb-5">
      <button onclick="confirmBooking()" class="w-full bg-gradient-to-r from-farm-600 to-farm-700 hover:from-farm-700 hover:to-farm-800 text-white font-bold py-3.5 rounded-xl transition-all shadow-lg active:scale-[.99]">
        ✅ Confirm Booking
      </button>
      <p class="text-gray-400 text-xs text-center mt-2">No advance payment needed. Pay on arrival.</p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  let currentPrice = 800;

  function openBookingModal(name, price) {
    currentPrice = parseInt(price);
    document.getElementById('modal-equip-name').textContent = name;
    document.getElementById('modal-equip-price').textContent = '₹' + parseInt(price).toLocaleString('en-IN') + '/day';
    document.getElementById('modal-total').textContent = '₹' + parseInt(price).toLocaleString('en-IN');
    // Set min date to today
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('book-start').min = today;
    document.getElementById('book-start').value = today;
    document.getElementById('booking-modal').classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
  }

  function closeBookingModal() {
    document.getElementById('booking-modal').classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }

  function updateTotal() {
    const days = parseInt(document.getElementById('book-days').value);
    document.getElementById('modal-total').textContent = '₹' + (currentPrice * days).toLocaleString('en-IN');
  }

  function confirmBooking() {
    addToCartAndConfirm(document.getElementById('modal-equip-name').textContent, currentPrice, '🚜');
    closeBookingModal();
    showToast('Booking Confirmed! 🎉', 'You will receive an SMS confirmation shortly.', '✅');
  }

  // Payment option toggle
  document.querySelectorAll('input[name="payment"]').forEach(input => {
    input.addEventListener('change', () => {
      document.querySelectorAll('.payment-label').forEach(l => l.classList.remove('active-payment'));
      input.nextElementSibling.classList.add('active-payment');
    });
  });

  // Close modal on overlay click
  document.getElementById('booking-modal').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeBookingModal();
  });

  // Filter logic
  function filterEquipment() {
    const location = document.getElementById('filter-location').value.toLowerCase();
    const maxPrice = parseInt(document.getElementById('price-range').value);
    const checkedCats = [...document.querySelectorAll('input[type=checkbox]:checked')].map(c => c.value);
    const avail = document.getElementById('filter-avail').value;

    const cards = document.querySelectorAll('.equip-card[data-category]');
    let visible = 0;

    cards.forEach(card => {
      const cardPrice = parseInt(card.dataset.price);
      const cardLocation = (card.dataset.location || '').toLowerCase();
      const cardCat = card.dataset.category;

      const priceOk = cardPrice <= maxPrice;
      const locationOk = !location || cardLocation.includes(location);
      const catOk = checkedCats.length === 0 || checkedCats.includes(cardCat);

      if (priceOk && locationOk && catOk) {
        card.classList.remove('hidden');
        visible++;
      } else {
        card.classList.add('hidden');
      }
    });

    document.getElementById('result-count').textContent = visible + ' equipment' + (visible !== 1 ? 's' : '');
    document.getElementById('no-results').classList.toggle('hidden', visible > 0);
  }

  function updatePriceLabel() {
    const v = parseInt(document.getElementById('price-range').value);
    document.getElementById('price-label').textContent = '₹' + v.toLocaleString('en-IN');
  }

  function clearFilters() {
    document.getElementById('filter-location').value = '';
    document.getElementById('price-range').value = 3000;
    document.getElementById('filter-avail').value = '';
    document.querySelectorAll('input[type=checkbox]').forEach(c => c.checked = false);
    updatePriceLabel();
    filterEquipment();
  }
</script>
