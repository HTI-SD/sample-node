<%- include('partials/header', { title: 'AI Disease Detection – FarmSeva', activePage: 'disease' }) %>

<div class="bg-gradient-to-r from-farm-900 to-farm-700 py-12 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-center space-x-2 text-farm-300 text-sm mb-3">
      <a href="/" class="hover:text-white">Home</a><span>/</span>
      <span class="text-white">Disease Detection AI</span>
    </div>
    <div class="flex items-center space-x-3">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">🔬 AI Disease Detection</h1>
      <span class="bg-soil-500 text-white text-sm px-3 py-1 rounded-full font-bold animate-pulse-soft">FREE</span>
    </div>
    <p class="text-farm-200">Upload a photo of your sick crop. Our AI identifies the disease and suggests treatment instantly.</p>
  </div>
</div>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <!-- Steps indicator -->
  <div class="flex items-center justify-center space-x-4 mb-10" data-aos="fade-up">
    <div class="step-indicator active-step">
      <div class="step-circle">1</div>
      <span class="step-label">Upload Photo</span>
    </div>
    <div class="step-line" id="line-1-2"></div>
    <div class="step-indicator" id="step-2">
      <div class="step-circle inactive-step-circle">2</div>
      <span class="step-label text-gray-400">AI Analysis</span>
    </div>
    <div class="step-line" id="line-2-3"></div>
    <div class="step-indicator" id="step-3">
      <div class="step-circle inactive-step-circle">3</div>
      <span class="step-label text-gray-400">Get Results</span>
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-8">

    <!-- Upload Panel -->
    <div data-aos="fade-right">
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6">
        <h3 class="font-bold text-gray-900 text-lg mb-1">📸 Upload Crop Photo</h3>
        <p class="text-gray-500 text-sm mb-5">Take a clear photo of the affected leaf, fruit, or stem.</p>

        <!-- Drag drop area -->
        <div id="upload-area" onclick="triggerUpload()"
          class="border-2 border-dashed border-farm-300 rounded-2xl p-8 text-center cursor-pointer hover:border-farm-500 hover:bg-farm-50 transition-all group">
          <div id="upload-placeholder">
            <div class="text-6xl mb-3 group-hover:scale-110 transition-transform">🌿</div>
            <p class="text-gray-700 font-semibold">Drop photo here or click to upload</p>
            <p class="text-gray-400 text-sm mt-1">Supports JPG, PNG — max 10MB</p>
            <div class="mt-4 inline-flex items-center space-x-2 bg-farm-600 text-white px-5 py-2 rounded-full text-sm font-semibold">
              <span>📷</span><span>Choose Photo</span>
            </div>
          </div>
          <div id="upload-preview" class="hidden">
            <div class="text-8xl mb-2" id="preview-emoji">🌿</div>
            <p class="text-farm-700 font-semibold text-sm" id="preview-name">photo.jpg</p>
          </div>
        </div>
        <input type="file" id="file-input" class="hidden" accept="image/*" onchange="handleFileSelect(this)">

        <!-- Crop type selector -->
        <div class="mt-5">
          <label class="block text-sm font-semibold text-gray-700 mb-2">🌾 Select Crop Type</label>
          <div class="grid grid-cols-3 gap-2">
            <button onclick="selectCrop(this, 'Tomato')" class="crop-btn active-crop">🍅 Tomato</button>
            <button onclick="selectCrop(this, 'Wheat')" class="crop-btn">🌾 Wheat</button>
            <button onclick="selectCrop(this, 'Cotton')" class="crop-btn">🌿 Cotton</button>
            <button onclick="selectCrop(this, 'Rice')" class="crop-btn">🍚 Rice</button>
            <button onclick="selectCrop(this, 'Potato')" class="crop-btn">🥔 Potato</button>
            <button onclick="selectCrop(this, 'Other')" class="crop-btn">🌱 Other</button>
          </div>
        </div>

        <!-- Analyze button -->
        <button id="analyze-btn" onclick="startAnalysis()" class="w-full mt-5 bg-gradient-to-r from-farm-600 to-farm-700 hover:from-farm-700 hover:to-farm-800 text-white font-bold py-3.5 rounded-2xl transition-all shadow-lg flex items-center justify-center space-x-2">
          <span>🔬</span>
          <span id="analyze-btn-text">Analyze with AI</span>
        </button>

        <!-- Sample images -->
        <div class="mt-5">
          <p class="text-gray-400 text-xs mb-2 text-center">Try with sample images:</p>
          <div class="flex justify-center gap-3">
            <button onclick="useSample('🍅', 'tomato_leaf.jpg', 'Tomato')" class="sample-img-btn">🍅<br><span class="text-xs">Tomato</span></button>
            <button onclick="useSample('🌾', 'wheat_stem.jpg', 'Wheat')" class="sample-img-btn">🌾<br><span class="text-xs">Wheat</span></button>
            <button onclick="useSample('🥔', 'potato_leaf.jpg', 'Potato')" class="sample-img-btn">🥔<br><span class="text-xs">Potato</span></button>
          </div>
        </div>
      </div>
    </div>

    <!-- Results Panel -->
    <div data-aos="fade-left">

      <!-- Idle state -->
      <div id="result-idle" class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 text-center h-full flex flex-col items-center justify-center">
        <div class="text-7xl mb-4">🤖</div>
        <h3 class="font-bold text-gray-700 text-lg mb-2">AI Ready</h3>
        <p class="text-gray-400 text-sm max-w-xs">Upload a photo of your crop and click "Analyze" to get instant disease detection and treatment recommendations.</p>
        <div class="mt-6 grid grid-cols-3 gap-3 w-full max-w-xs">
          <div class="text-center">
            <div class="text-2xl">🎯</div>
            <div class="text-xs text-gray-500 mt-1">94% Accuracy</div>
          </div>
          <div class="text-center">
            <div class="text-2xl">⚡</div>
            <div class="text-xs text-gray-500 mt-1">&lt;5 sec Results</div>
          </div>
          <div class="text-center">
            <div class="text-2xl">🌿</div>
            <div class="text-xs text-gray-500 mt-1">50+ Diseases</div>
          </div>
        </div>
      </div>

      <!-- Loading state -->
      <div id="result-loading" class="hidden bg-white rounded-3xl shadow-sm border border-gray-100 p-8 text-center h-full flex flex-col items-center justify-center">
        <div class="w-20 h-20 border-4 border-farm-200 border-t-farm-600 rounded-full animate-spin mb-6"></div>
        <h3 class="font-bold text-gray-700 text-lg mb-2">Analyzing your crop...</h3>
        <div class="space-y-2 text-sm text-gray-500">
          <div class="loading-step" id="ls-1">✓ Image uploaded successfully</div>
          <div class="loading-step opacity-0" id="ls-2">⚙ Processing with AI model...</div>
          <div class="loading-step opacity-0" id="ls-3">🔬 Checking for diseases...</div>
          <div class="loading-step opacity-0" id="ls-4">💊 Preparing treatment plan...</div>
        </div>
      </div>

      <!-- Results state -->
      <div id="result-output" class="hidden bg-white rounded-3xl shadow-sm border border-gray-100 p-6">
        <div class="flex items-center space-x-2 mb-4">
          <span class="text-2xl">🔬</span>
          <h3 class="font-bold text-gray-900 text-lg">Analysis Results</h3>
          <span class="ml-auto bg-farm-100 text-farm-700 text-xs px-2 py-0.5 rounded-full font-medium" id="crop-badge">Tomato</span>
        </div>

        <!-- Disease detected -->
        <div class="bg-red-50 border border-red-200 rounded-2xl p-4 mb-4">
          <div class="flex items-start justify-between mb-2">
            <div class="flex items-center space-x-2">
              <span class="text-2xl">⚠️</span>
              <div>
                <p class="font-bold text-red-700 text-sm" id="disease-name">Late Blight Detected</p>
                <p class="text-red-500 text-xs" id="disease-scientific">Phytophthora infestans</p>
              </div>
            </div>
            <div class="text-right">
              <div class="text-red-700 font-bold text-lg" id="confidence-pct">94%</div>
              <div class="text-red-400 text-xs">Confidence</div>
            </div>
          </div>
          <!-- Confidence bar -->
          <div class="h-2 bg-red-100 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-red-500 to-red-600 rounded-full transition-all duration-1000" id="confidence-bar" style="width:0%"></div>
          </div>
        </div>

        <!-- Severity -->
        <div class="flex items-center space-x-3 mb-4">
          <span class="text-sm text-gray-600 font-medium">Severity:</span>
          <div class="flex space-x-1">
            <span class="severity-dot bg-red-500"></span>
            <span class="severity-dot bg-red-500"></span>
            <span class="severity-dot bg-red-500"></span>
            <span class="severity-dot bg-gray-200"></span>
            <span class="severity-dot bg-gray-200"></span>
          </div>
          <span class="text-sm font-semibold text-red-600">High</span>
        </div>

        <!-- Treatment -->
        <div class="bg-farm-50 border border-farm-200 rounded-2xl p-4 mb-4">
          <p class="font-bold text-farm-800 text-sm mb-2">💊 Recommended Treatment</p>
          <ul class="space-y-1 text-xs text-gray-700" id="treatment-list">
            <li class="flex items-start space-x-2"><span class="text-farm-600 mt-0.5">•</span><span>Apply <strong>Mancozeb 75% WP</strong> @ 2g/liter every 7 days</span></li>
            <li class="flex items-start space-x-2"><span class="text-farm-600 mt-0.5">•</span><span>Remove and destroy all infected plant material immediately</span></li>
            <li class="flex items-start space-x-2"><span class="text-farm-600 mt-0.5">•</span><span>Avoid overhead irrigation; use drip system</span></li>
            <li class="flex items-start space-x-2"><span class="text-farm-600 mt-0.5">•</span><span>Spray <strong>Copper Oxychloride 50% WP</strong> as preventive</span></li>
          </ul>
        </div>

        <!-- Prevention tips -->
        <div class="bg-soil-50 border border-soil-200 rounded-2xl p-3 mb-4">
          <p class="font-bold text-soil-800 text-xs mb-1">🛡 Prevention for Next Season</p>
          <p class="text-xs text-gray-600" id="prevention-tip">Use certified disease-resistant tomato varieties. Practice crop rotation every 2 years.</p>
        </div>

        <!-- CTA -->
        <button onclick="openConsultFromDisease()" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-semibold py-3 rounded-xl transition-colors text-sm flex items-center justify-center space-x-2">
          <span>👨‍💼</span>
          <span>Talk to Crop Expert (Free)</span>
        </button>
        <button onclick="resetAnalysis()" class="w-full mt-2 border border-gray-200 text-gray-600 hover:bg-gray-50 font-medium py-2.5 rounded-xl transition-colors text-sm">
          🔄 Analyze Another Photo
        </button>
      </div>

    </div>
  </div>

  <!-- Supported diseases section -->
  <div class="mt-12" data-aos="fade-up">
    <h3 class="text-xl font-bold text-gray-900 mb-5 text-center">🌿 Diseases We Can Detect</h3>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
      <% const diseases = [
        {emoji:'🍅', name:'Tomato Blight', crop:'Tomato'},
        {emoji:'🌾', name:'Wheat Rust', crop:'Wheat'},
        {emoji:'🌿', name:'Powdery Mildew', crop:'Multiple'},
        {emoji:'🥔', name:'Potato Rot', crop:'Potato'},
        {emoji:'🌽', name:'Corn Smut', crop:'Corn'},
        {emoji:'🍚', name:'Rice Blast', crop:'Rice'},
        {emoji:'🫑', name:'Pepper Blight', crop:'Pepper'},
        {emoji:'🥦', name:'Downy Mildew', crop:'Vegetable'},
        {emoji:'🍆', name:'Bacterial Wilt', crop:'Eggplant'},
        {emoji:'🌻', name:'Sunflower Rust', crop:'Sunflower'},
        {emoji:'🫘', name:'Soybean Mosaic', crop:'Soybean'},
        {emoji:'🧅', name:'Onion Purple Blotch', crop:'Onion'},
      ]; %>
      <% diseases.forEach(d => { %>
      <div class="bg-white rounded-xl p-3 text-center shadow-sm border border-gray-100 hover:border-farm-300 transition-all">
        <div class="text-3xl mb-1"><%= d.emoji %></div>
        <p class="text-xs font-semibold text-gray-700"><%= d.name %></p>
        <p class="text-xs text-gray-400"><%= d.crop %></p>
      </div>
      <% }) %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  let selectedCrop = 'Tomato';

  function selectCrop(btn, crop) {
    document.querySelectorAll('.crop-btn').forEach(b => b.classList.remove('active-crop'));
    btn.classList.add('active-crop');
    selectedCrop = crop;
  }

  function triggerUpload() {
    document.getElementById('file-input').click();
  }

  function handleFileSelect(input) {
    if (input.files && input.files[0]) {
      const fname = input.files[0].name;
      document.getElementById('preview-emoji').textContent = '📸';
      document.getElementById('preview-name').textContent = fname;
      document.getElementById('upload-placeholder').classList.add('hidden');
      document.getElementById('upload-preview').classList.remove('hidden');
    }
  }

  function useSample(emoji, name, crop) {
    document.getElementById('preview-emoji').textContent = emoji;
    document.getElementById('preview-name').textContent = name;
    document.getElementById('upload-placeholder').classList.add('hidden');
    document.getElementById('upload-preview').classList.remove('hidden');
    document.querySelectorAll('.crop-btn').forEach(b => {
      if (b.textContent.includes(crop)) { b.click(); }
    });
  }

  const diseaseData = {
    Tomato: { disease: 'Late Blight Detected', scientific: 'Phytophthora infestans', confidence: 94, treatment: ['Apply <strong>Mancozeb 75% WP</strong> @ 2g/liter every 7 days', 'Remove and destroy all infected plant material', 'Avoid overhead irrigation; switch to drip system', 'Spray <strong>Copper Oxychloride 50% WP</strong> as preventive'], prevention: 'Use certified disease-resistant tomato varieties. Practice crop rotation every 2 years.' },
    Wheat: { disease: 'Yellow Rust Detected', scientific: 'Puccinia striiformis', confidence: 89, treatment: ['Apply <strong>Propiconazole 25% EC</strong> @ 0.1% immediately', 'Remove infected tillers and burn them', 'Ensure proper spacing for air circulation', 'Use resistant wheat varieties next season'], prevention: 'Sow resistant varieties. Avoid late sowing in high-risk areas.' },
    Potato: { disease: 'Early Blight Detected', scientific: 'Alternaria solani', confidence: 91, treatment: ['Apply <strong>Chlorothalonil 75% WP</strong> @ 2g/liter', 'Remove lower infected leaves', 'Improve drainage around plants', 'Spray at 7–10 day intervals until harvest'], prevention: 'Use certified seed tubers. Avoid excessive nitrogen fertilizers.' },
    Rice: { disease: 'Blast Disease Detected', scientific: 'Magnaporthe oryzae', confidence: 87, treatment: ['Apply <strong>Tricyclazole 75% WP</strong> @ 0.6g/liter', 'Drain field and allow to dry for 2–3 days', 'Avoid excess nitrogen; balance NPK ratio', 'Spray <strong>Carbendazim 50% WP</strong> preventively'], prevention: 'Use blast-resistant rice varieties. Maintain proper water management.' },
    Cotton: { disease: 'Leaf Curl Virus', scientific: 'Cotton Leaf Curl Virus (CLCuV)', confidence: 85, treatment: ['Remove and destroy infected plants immediately', 'Apply <strong>Imidacloprid 17.8% SL</strong> to control whiteflies', 'Spray <strong>Neem oil 3%</strong> every 10 days', 'Avoid planting near infected fields'], prevention: 'Use virus-resistant cotton hybrids. Early planting reduces infection risk.' },
    Other: { disease: 'Powdery Mildew Detected', scientific: 'Erysiphe sp.', confidence: 82, treatment: ['Apply <strong>Sulphur 80% WP</strong> @ 3g/liter', 'Improve air circulation by pruning', 'Reduce humidity around plants', 'Use <strong>Wettable sulphur</strong> as preventive spray'], prevention: 'Avoid overhead watering. Plant in sunny, well-ventilated locations.' },
  };

  function startAnalysis() {
    const preview = document.getElementById('upload-preview');
    if (preview.classList.contains('hidden')) {
      showToast('Please upload a photo first!', 'Select a crop photo before analyzing.', '⚠️');
      return;
    }

    document.getElementById('result-idle').classList.add('hidden');
    document.getElementById('result-output').classList.add('hidden');
    document.getElementById('result-loading').classList.remove('hidden');

    // Animate loading steps
    const steps = ['ls-1', 'ls-2', 'ls-3', 'ls-4'];
    steps.forEach((id, i) => {
      setTimeout(() => {
        document.getElementById(id).classList.remove('opacity-0');
      }, i * 700);
    });

    // Animate step indicators
    document.getElementById('line-1-2').classList.add('active-step-line');
    setTimeout(() => {
      document.getElementById('step-2').querySelector('.step-circle').className = 'step-circle';
      document.getElementById('step-2').querySelector('.step-label').classList.remove('text-gray-400');
    }, 1400);

    setTimeout(() => {
      document.getElementById('line-2-3').classList.add('active-step-line');
      document.getElementById('step-3').querySelector('.step-circle').className = 'step-circle';
      document.getElementById('step-3').querySelector('.step-label').classList.remove('text-gray-400');
    }, 2100);

    setTimeout(() => showResults(), 3200);
  }

  function showResults() {
    const data = diseaseData[selectedCrop] || diseaseData.Other;
    document.getElementById('result-loading').classList.add('hidden');
    document.getElementById('result-output').classList.remove('hidden');
    document.getElementById('crop-badge').textContent = selectedCrop;
    document.getElementById('disease-name').textContent = data.disease;
    document.getElementById('disease-scientific').textContent = data.scientific;
    document.getElementById('confidence-pct').textContent = data.confidence + '%';
    document.getElementById('prevention-tip').textContent = data.prevention;
    document.getElementById('treatment-list').innerHTML = data.treatment.map(t =>
      `<li class="flex items-start space-x-2"><span class="text-farm-600 mt-0.5">•</span><span>${t}</span></li>`
    ).join('');

    setTimeout(() => {
      document.getElementById('confidence-bar').style.width = data.confidence + '%';
    }, 100);
  }

  function resetAnalysis() {
    document.getElementById('result-output').classList.add('hidden');
    document.getElementById('result-idle').classList.remove('hidden');
    document.getElementById('upload-placeholder').classList.remove('hidden');
    document.getElementById('upload-preview').classList.add('hidden');
    document.getElementById('confidence-bar').style.width = '0%';
    // Reset steps
    ['ls-1','ls-2','ls-3','ls-4'].forEach(id => document.getElementById(id).classList.add('opacity-0'));
    document.getElementById('ls-1').classList.remove('opacity-0');
  }

  function openConsultFromDisease() {
    window.location.href = '/consultation';
  }
</script>
