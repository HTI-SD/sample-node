<!DOCTYPE html>
<html lang="en" id="html-root">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FarmSeva – <%= typeof title !== 'undefined' ? title : 'Farming Made Easy' %></title>
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
  <link rel="alternate icon" href="/images/favicon.svg">
  <meta name="theme-color" content="#15803d">
  <!-- OG / Social -->
  <meta property="og:title" content="FarmSeva – Farming Made Easy">
  <meta property="og:description" content="On-demand agricultural services for every Indian farmer.">
  <meta property="og:image" content="/images/logo.svg">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Noto+Sans+Devanagari:wght@400;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/aos@2.3.1/dist/aos.css">
  <link rel="stylesheet" href="/styles/styles.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { poppins: ['Poppins', 'sans-serif'] },
          colors: {
            farm: { 50:'#f0fdf4',100:'#dcfce7',200:'#bbf7d0',300:'#86efac',400:'#4ade80',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d' },
            soil: { 50:'#fefce8',100:'#fef9c3',200:'#fef08a',300:'#fde047',400:'#facc15',500:'#eab308',600:'#ca8a04',700:'#a16207',800:'#854d0e',900:'#713f12' },
          },
          animation: {
            'float':'float 6s ease-in-out infinite',
            'pulse-soft':'pulseSoft 3s ease-in-out infinite',
            'bounce-in':'bounceIn 0.4s ease-out',
          },
          keyframes: {
            float:{'0%,100%':{transform:'translateY(0px)'},'50%':{transform:'translateY(-20px)'}},
            pulseSoft:{'0%,100%':{opacity:'0.8'},'50%':{opacity:'1'}},
            bounceIn:{'0%':{transform:'scale(0.3)',opacity:'0'},'60%':{transform:'scale(1.1)'},'100%':{transform:'scale(1)',opacity:'1'}},
            slideUp:{'0%':{opacity:'0',transform:'translateY(20px)'},'100%':{opacity:'1',transform:'translateY(0)'}},
          }
        }
      }
    }
  </script>
</head>
<body class="font-poppins bg-gray-50 text-gray-800">

<!-- Navigation -->
<nav class="fixed top-0 left-0 right-0 z-50" id="navbar">
  <div class="bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- Logo -->
        <a href="/" class="flex items-center space-x-2.5 group flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 44 44" class="h-11 w-11 group-hover:scale-105 transition-transform flex-shrink-0" aria-hidden="true">
            <!-- Green rounded bg -->
            <rect width="44" height="44" rx="10" fill="#15803d"/>
            <!-- Ground strip -->
            <rect x="0" y="36" width="44" height="8" fill="#166534"/>
            <rect x="0" y="33" width="44" height="5" rx="2" fill="#16a34a" opacity="0.55"/>
            <!-- Wheat left stalk -->
            <line x1="8" y1="33" x2="8" y2="13" stroke="#fbbf24" stroke-width="2" stroke-linecap="round"/>
            <ellipse cx="8" cy="10" rx="3" ry="5.5" fill="#fbbf24" transform="rotate(-5,8,10)"/>
            <line x1="8" y1="23" x2="4" y2="17" stroke="#fbbf24" stroke-width="1.5" stroke-linecap="round"/>
            <ellipse cx="3" cy="14.5" rx="2.5" ry="4.5" fill="#fbbf24" transform="rotate(-18,3,14.5)"/>
            <line x1="8" y1="28" x2="12" y2="22" stroke="#fbbf24" stroke-width="1.5" stroke-linecap="round"/>
            <ellipse cx="13" cy="19.5" rx="2.5" ry="4" fill="#fbbf24" transform="rotate(15,13,19.5)"/>
            <!-- Wheat right stalk -->
            <line x1="36" y1="33" x2="36" y2="13" stroke="#fbbf24" stroke-width="2" stroke-linecap="round"/>
            <ellipse cx="36" cy="10" rx="3" ry="5.5" fill="#fbbf24" transform="rotate(5,36,10)"/>
            <line x1="36" y1="23" x2="40" y2="17" stroke="#fbbf24" stroke-width="1.5" stroke-linecap="round"/>
            <ellipse cx="41" cy="14.5" rx="2.5" ry="4.5" fill="#fbbf24" transform="rotate(18,41,14.5)"/>
            <line x1="36" y1="28" x2="32" y2="22" stroke="#fbbf24" stroke-width="1.5" stroke-linecap="round"/>
            <ellipse cx="31" cy="19.5" rx="2.5" ry="4" fill="#fbbf24" transform="rotate(-15,31,19.5)"/>
            <!-- Tractor body -->
            <rect x="12" y="22" width="20" height="12" rx="3" fill="white" opacity="0.92"/>
            <!-- Cab -->
            <rect x="20" y="15" width="13" height="10" rx="2.5" fill="white" opacity="0.88"/>
            <!-- Window -->
            <rect x="22" y="17" width="9" height="6" rx="1.5" fill="#7dd3fc" opacity="0.9"/>
            <!-- Exhaust pipe -->
            <rect x="20" y="10" width="3.5" height="7" rx="1.5" fill="#d1d5db"/>
            <circle cx="21.5" cy="9" r="2.5" fill="#e5e7eb" opacity="0.55"/>
            <!-- Rear wheel -->
            <circle cx="18" cy="35" r="7" fill="#1c1917"/>
            <circle cx="18" cy="35" r="4.5" fill="#292524"/>
            <circle cx="18" cy="35" r="2" fill="#1c1917"/>
            <circle cx="18" cy="35" r="7" fill="none" stroke="#44403c" stroke-width="1.5" stroke-dasharray="3 4"/>
            <!-- Front wheel -->
            <circle cx="30" cy="36" r="5" fill="#1c1917"/>
            <circle cx="30" cy="36" r="3" fill="#292524"/>
            <circle cx="30" cy="36" r="1.2" fill="#1c1917"/>
            <circle cx="30" cy="36" r="5" fill="none" stroke="#44403c" stroke-width="1.2" stroke-dasharray="2 3"/>
            <!-- Location pin (amber, top-right corner) -->
            <path d="M37,3 C34.5,3 32.5,5 32.5,7.5 C32.5,11 37,16 37,16 C37,16 41.5,11 41.5,7.5 C41.5,5 39.5,3 37,3 Z" fill="#f59e0b"/>
            <circle cx="37" cy="7.5" r="2.5" fill="white" opacity="0.9"/>
            <circle cx="37" cy="7.5" r="1.2" fill="#f59e0b"/>
          </svg>
          <div class="flex items-baseline leading-none">
            <span class="text-[22px] font-black text-farm-800 tracking-tight">Farm</span>
            <span class="text-[22px] font-black text-soil-600 tracking-tight">सेवा</span>
          </div>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden xl:flex items-center space-x-0.5">
          <a href="/equipment" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='equipment'?'nav-active':'' %>">
            <span>🚜</span><span data-translate="nav-equipment">Equipment</span>
          </a>
          <a href="/labour" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='labour'?'nav-active':'' %>">
            <span>👨‍🌾</span><span data-translate="nav-labour">Labour</span>
          </a>
          <a href="/consultation" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='consultation'?'nav-active':'' %>">
            <span>👨‍💼</span><span data-translate="nav-experts">Experts</span>
          </a>
          <a href="/disease" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='disease'?'nav-active':'' %>">
            <span>🔬</span><span data-translate="nav-disease">Disease AI</span>
          </a>
          <a href="/weather" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='weather'?'nav-active':'' %>">
            <span>🌤</span><span data-translate="nav-weather">Weather</span>
          </a>
          <a href="/group-booking" class="nav-link <%= typeof activePage!=='undefined'&&activePage==='group'?'nav-active':'' %>">
            <span>👥</span><span data-translate="nav-group">Group</span>
          </a>
        </div>

        <!-- Right actions -->
        <div class="flex items-center space-x-2">

          <!-- Language toggle -->
          <button id="lang-toggle" class="hidden sm:flex items-center space-x-1 text-xs font-semibold text-gray-500 hover:text-farm-600 border border-gray-200 rounded-full px-3 py-1.5 hover:border-farm-300 transition-all" title="Switch Language">
            <span id="lang-flag">🇮🇳</span>
            <span id="lang-text">हिंदी</span>
          </button>

          <!-- Cart / My Bookings -->
          <a href="/my-bookings" class="relative flex items-center space-x-1 text-gray-600 hover:text-farm-600 transition-colors p-2 rounded-xl hover:bg-farm-50" title="My Bookings">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
            <span id="cart-badge" class="hidden absolute -top-0.5 -right-0.5 w-5 h-5 bg-red-500 text-white text-xs font-bold rounded-full flex items-center justify-center animate-bounce-in">0</span>
            <span class="hidden lg:inline text-sm font-medium" data-translate="nav-my-bookings">My Bookings</span>
          </a>

          <!-- Become Provider -->
          <a href="/become-provider" class="hidden md:flex items-center space-x-1 border border-farm-300 text-farm-700 hover:bg-farm-50 px-3 py-1.5 rounded-full font-semibold text-xs transition-all">
            <span>💼</span>
            <span data-translate="nav-become-provider">Earn with Us</span>
          </a>

          <!-- Book Now CTA -->
          <a href="/equipment" class="hidden sm:inline-flex items-center bg-gradient-to-r from-farm-600 to-farm-700 hover:from-farm-700 hover:to-farm-800 text-white px-4 py-2 rounded-full font-semibold text-sm transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5">
            <span data-translate="nav-book-now">Book Now</span>
          </a>

          <!-- Mobile hamburger -->
          <button id="mobile-menu-btn" class="xl:hidden p-2 rounded-xl text-gray-500 hover:bg-gray-100 transition-colors">
            <svg id="menu-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden xl:hidden border-t border-gray-100 bg-white">
      <div class="px-4 py-3 grid grid-cols-2 gap-2">
        <a href="/equipment"     class="mobile-nav-link">🚜 <span data-translate="mobile-equipment">Equipment Rental</span></a>
        <a href="/labour"        class="mobile-nav-link">👨‍🌾 <span data-translate="mobile-labour">Labour Booking</span></a>
        <a href="/consultation"  class="mobile-nav-link">👨‍💼 <span data-translate="mobile-experts">Expert Consult</span></a>
        <a href="/disease"       class="mobile-nav-link">🔬 <span data-translate="mobile-disease">Disease AI</span></a>
        <a href="/weather"       class="mobile-nav-link">🌤 <span data-translate="mobile-weather">Weather</span></a>
        <a href="/group-booking" class="mobile-nav-link">👥 <span data-translate="mobile-group">Group Booking</span></a>
        <a href="/my-bookings"   class="mobile-nav-link">🛒 <span data-translate="mobile-bookings">My Bookings</span></a>
        <a href="/become-provider" class="mobile-nav-link">💼 <span data-translate="mobile-provider">Earn with Us</span></a>
      </div>
      <div class="px-4 pb-3 grid grid-cols-2 gap-2">
        <a href="/equipment" class="text-center bg-farm-600 text-white py-2.5 rounded-xl font-semibold text-sm" data-translate="nav-book-now">Book a Service</a>
        <button id="mobile-lang-toggle" class="text-center border border-farm-300 text-farm-700 py-2.5 rounded-xl font-semibold text-sm">🇮🇳 हिंदी / EN</button>
      </div>
    </div>
  </div>
</nav>

<!-- Spacer for fixed nav -->
<div class="h-16"></div>
